# ======================================================
# ARCADINS Training Center — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# Ne committez JAMAIS le fichier .env sur GitHub !
# ======================================================

# Serveur
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://arcadins-training.onrender.com

# Base de données SQLite
# En local : laisser vide (utilise server/arcadins.db)
# Sur Render : /data/arcadins.db (disque persistant monté)
DATABASE_PATH=

# JWT — Clé secrète (générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGEZ_MOI_AVEC_UNE_CLE_ALEATOIRE_LONGUE

# Stripe (récupérez vos clés sur https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP Hostinger (https://hpanel.hostinger.com → Emails → SMTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@arcadins-training.com
SMTP_PASS=VOTRE_MOT_DE_PASSE_EMAIL

# Email administrateur (reçoit toutes les notifications en BCC)
ADMIN_EMAIL=arcadinstrainingcenter@gmail.com
